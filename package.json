{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "crm",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "format": "prettier --write \"resources/frontend/crm/**/*.{css,js,json,ts,tsx,md}\" resources/frontend/README.md",
        "format:check": "prettier --check \"resources/frontend/crm/**/*.{css,js,json,ts,tsx,md}\" resources/frontend/README.md",
        "lint": "eslint resources/frontend/crm --max-warnings=0",
        "typecheck": "tsc --noEmit -p tsconfig.frontend.json",
        "test:unit": "vitest run",
        "test:e2e": "playwright test"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.61.1",
        "@tailwindcss/vite": "^4.0.0",
        "@types/node": "^25.9.5",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.2.0",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "eslint": "^10.7.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "globals": "^17.7.0",
        "jsdom": "^28.1.0",
        "laravel-vite-plugin": "^2.0.0",
        "playwright": "^1.61.1",
        "prettier": "^3.9.5",
        "tailwindcss": "^4.0.0",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.64.0",
        "vite": "^7.0.7",
        "vitest": "^4.1.10"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@iconify-icons/solar": "^1.2.3",
        "@iconify/react": "^6.0.2",
        "@tiptap/extension-placeholder": "^3.28.0",
        "@tiptap/react": "^3.28.0",
        "@tiptap/starter-kit": "^3.28.0",
        "chart.js": "^4.5.1",
        "chartjs-chart-financial": "^0.2.1",
        "react": "^19.2.7",
        "react-chartjs-2": "^5.3.1",
        "react-dom": "^19.2.7",
        "react-router": "^8.2.0",
        "swiper": "^12.2.0",
        "yet-another-react-lightbox": "^3.32.1"
    }
}
