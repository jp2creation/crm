{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "ext-gd": "*",
        "php": "^8.3",
        "filament/filament": "^5.0",
        "laravel/framework": "^12.0",
        "laravel/horizon": "^5.47",
        "laravel/sanctum": "^4.3",
        "laravel/tinker": "^2.10.1",
        "nwidart/laravel-modules": "^12.0",
        "sentry/sentry-laravel": "^4.27",
        "spatie/laravel-activitylog": "^4.12",
        "spatie/laravel-permission": "^6.25"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.4",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3",
        "laravel/boost": "^2.4",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.24",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpstan/phpstan-phpunit": "^2",
        "phpunit/phpunit": "^11.5.50"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Modules\\": "Modules/",
            "Modules\\CrmAdministration\\": "Modules/CrmAdministration/app/",
            "Modules\\CrmCashControl\\": "Modules/CrmCashControl/app/",
            "Modules\\CrmCheckRemittances\\": "Modules/CrmCheckRemittances/app/",
            "Modules\\CrmCore\\": "Modules/CrmCore/app/",
            "Modules\\CrmDepositRequests\\": "Modules/CrmDepositRequests/app/",
            "Modules\\CrmEquipmentRentals\\": "Modules/CrmEquipmentRentals/app/",
            "Modules\\CrmLeaves\\": "Modules/CrmLeaves/app/",
            "Modules\\CrmPages\\": "Modules/CrmPages/app/",
            "Modules\\CrmReservations\\": "Modules/CrmReservations/app/",
            "Modules\\CrmSalesTours\\": "Modules/CrmSalesTours/app/",
            "Modules\\CrmTeams\\": "Modules/CrmTeams/app/",
            "Modules\\CrmTapisRomus\\": "Modules/CrmTapisRomus/app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan horizon\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,horizon,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "test:mysql-critical": [
            "@php artisan migrate:fresh --force --ansi",
            "@php artisan test tests/Feature/CrmMysqlSchemaTest.php tests/Feature/CrmAdministrationApiTest.php tests/Feature/CrmReservationApiTest.php tests/Feature/CrmEquipmentRentalApiTest.php tests/Feature/CrmLeaveApiTest.php tests/Feature/CrmPolicyAuthorizationTest.php tests/Feature/CrmPerformanceOptimizationTest.php"
        ],
        "analyse": "vendor/bin/phpstan analyse --memory-limit=1G",
        "pint": "vendor/bin/pint --test app bootstrap/app.php config database Modules routes tests",
        "pint:fix": "vendor/bin/pint app bootstrap/app.php config database Modules routes tests",
        "test:coverage": [
            "@php -r \"is_dir('build/logs') || mkdir('build/logs', 0777, true);\"",
            "XDEBUG_MODE=coverage php artisan test --coverage-clover build/logs/clover.xml",
            "@php scripts/check-coverage.php build/logs/clover.xml 80"
        ],
        "quality": [
            "@composer pint",
            "@composer analyse",
            "@composer test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "merge-plugin": {
            "include": [
                "Modules/*/composer.json"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        },
        "platform": {
            "php": "8.3.17"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
