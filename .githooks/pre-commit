#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

if [ ! -x vendor/bin/pint ]; then
    echo "Laravel Pint est introuvable. Lancez d'abord: composer install" >&2
    exit 1
fi

PHP_FILES=()
while IFS= read -r file; do
    [ -n "$file" ] && PHP_FILES+=("$file")
done < <(
    git diff --cached --name-only --diff-filter=ACMR -- '*.php' |
        grep -E '^(app|bootstrap/app\.php|config|database|Modules|routes|tests)(/|$)' || true
)

if [ "${#PHP_FILES[@]}" -eq 0 ]; then
    exit 0
fi

echo "Verification Laravel Pint sur les fichiers PHP stages..."
vendor/bin/pint --test "${PHP_FILES[@]}"
