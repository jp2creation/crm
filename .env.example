APP_NAME="Martin Sols CRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

CRM_API_DEBUG=false
CRM_TRUST_LARAVEL_SESSION=true
CRM_ALLOW_LEGACY_ACTOR_IMPERSONATION=false
CRM_ALLOW_LEGACY_ACTOR_HEADER=false
CRM_ALLOW_LEGACY_ACTOR_BODY=false
CRM_LEGACY_PHP_API_ENABLED=false
CRM_LEGACY_PHP_API_LOG=true
CRM_LEGACY_PHP_API_THROTTLE_PER_MINUTE=60
CRM_FORCE_HTTPS=false
CRM_HSTS_ENABLED=false
CRM_HSTS_MAX_AGE=31536000
CRM_HSTS_INCLUDE_SUBDOMAINS=true
CRM_HSTS_PRELOAD=true
CRM_API_THROTTLE_PER_MINUTE=120
CRM_LOGIN_THROTTLE_PER_MINUTE=10
CRM_RESPONSE_COMPRESSION_ENABLED=true
CRM_RESPONSE_COMPRESSION_MIN_BYTES=1024
CRM_RESPONSE_COMPRESSION_LEVEL=6
CRM_BACKUP_DISK=local
CRM_BACKUP_PATH=backups/database
CRM_BACKUP_KEEP=14
CRM_LEAVE_DEFAULT_ENTITLEMENT_DAYS=25
CRM_LEAVE_EXCLUDE_WEEKENDS=false
CRM_LEAVE_ENFORCE_BALANCES=false
CRM_DASHBOARD_METRICS_ENABLED=true
CRM_QUEUE_ALERT_THRESHOLD=1000
CRM_QUEUE_ALERT_COOLDOWN_MINUTES=30
CRM_CASH_RECEIPT_ARCHIVE_AFTER_YEARS=3
CRM_INVOICE_REMINDER_DAYS=15,30
CRM_NOTIFICATION_LOCALE=fr
CRM_ADMIN_PASSWORD_MIN=12
CRM_ADMIN_HASH_ROUNDS=12
CRM_ASSET_VERSION=
CRM_CHECK_OCR_ENABLED=true
CRM_CHECK_OCR_PYTHON=python3
CRM_CHECK_OCR_SCRIPT=
CRM_CHECK_OCR_TIMEOUT=45
CORS_ALLOWED_ORIGINS=https://crm.jp2.fr,capacitor://localhost,ionic://localhost,http://localhost,http://localhost:8100

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=UTC
CRM_DISPLAY_TIMEZONE=Europe/Paris

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_DAILY_DAYS=30
LOG_LEVEL=debug
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT="${APP_ENV}"
SENTRY_RELEASE=
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=
SENTRY_SEND_DEFAULT_PII=false

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=crm
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_CONNECTION=session
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=none
SANCTUM_MOBILE_TOKEN_EXPIRATION_DAYS=365

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
REDIS_QUEUE_CONNECTION=queue
REDIS_QUEUE=default

CACHE_STORE=redis
REDIS_CACHE_CONNECTION=cache
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_SESSION_DB=3
REDIS_HORIZON_DB=4

HORIZON_NAME="${APP_NAME}"
HORIZON_PATH=horizon
HORIZON_REDIS_CONNECTION=horizon
HORIZON_QUEUE_WAIT_SECONDS=60
HORIZON_MAX_PROCESSES=2
HORIZON_MEMORY_LIMIT=128
HORIZON_WORKER_TIMEOUT=180
HORIZON_WORKER_TRIES=3
DEBUGBAR_ENABLED=null

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
