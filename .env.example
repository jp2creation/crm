APP_NAME="Martin Sols CRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

CRM_API_DEBUG=false
CRM_TRUST_LARAVEL_SESSION=true
CRM_ALLOW_LEGACY_ACTOR_IMPERSONATION=false
CRM_ALLOW_LEGACY_ACTOR_HEADER=false
CRM_ALLOW_LEGACY_ACTOR_BODY=false
CRM_LEGACY_PHP_API_ENABLED=true
CRM_LEGACY_PHP_API_LOG=true
CRM_LEGACY_PHP_API_THROTTLE_PER_MINUTE=60
CRM_API_THROTTLE_PER_MINUTE=120
CRM_LOGIN_THROTTLE_PER_MINUTE=10
CRM_ADMIN_PASSWORD_MIN=12
CRM_ADMIN_HASH_ROUNDS=12
CRM_ASSET_VERSION=
CORS_ALLOWED_ORIGINS=https://crm.jp2.fr,capacitor://localhost,ionic://localhost,http://localhost,http://localhost:8100

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=UTC
CRM_DISPLAY_TIMEZONE=Europe/Paris

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_DAILY_DAYS=30
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=crm
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SANCTUM_MOBILE_TOKEN_EXPIRATION_DAYS=365

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
